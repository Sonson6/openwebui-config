ENV=development

# ── OpenWebUI ─────────────────────────────────────────────────────────────────
OPENWEBUI_URL=http://localhost:3000
OPENWEBUI_API_KEY=your-dev-api-key

# OpenWebUI pointe vers LiteLLM (qui fait le routage vers les vrais providers)
OPENAI_API_BASE_URL=http://localhost:4000
OPENAI_API_KEY=your-litellm-master-key   # doit correspondre à LITELLM_MASTER_KEY

# ── LiteLLM ───────────────────────────────────────────────────────────────────
# Clé maître du proxy — commence obligatoirement par "sk-"
LITELLM_MASTER_KEY=sk-dev-change-me

# Clés des providers (les vraies, jamais commitées)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
