ENV=development

# ── OpenWebUI ─────────────────────────────────────────────────────────────────
# URL utilisée par les scripts (client.py, apply.py, etc.)
OPENWEBUI_URL=http://localhost:3000
OPENWEBUI_API_KEY=your-openwebui-api-key

# Clé secrète pour signer les sessions — générer avec :
# python3 -c "import secrets; print(secrets.token_hex(32))"
WEBUI_SECRET_KEY=change-me-32-hex-chars

# ── LiteLLM ───────────────────────────────────────────────────────────────────
# Clé maître du proxy — commence obligatoirement par "sk-"
LITELLM_MASTER_KEY=sk-dev-change-me

# Clés des providers (les vraies, jamais commitées)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Open Terminal ──────────────────────────────────────────────────────────────
# API key for the open-terminal sidecar. Acts as a shared secret between
# OpenWebUI and the terminal service. Generate a strong random value with:
#   openssl rand -hex 32
# In production, prefer OPEN_TERMINAL_API_KEY_FILE pointing to a Docker secret
# so the key never appears in docker inspect or the process environment.
OPEN_TERMINAL_API_KEY=change-me-openssl-rand-hex-32
