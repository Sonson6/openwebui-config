# Master variable reference — do not fill in values here.
# Instead copy the environment-specific template and fill that in:
#   cp .env.development.example .env.development
#   cp .env.production.example  .env.production
#
# ── OpenWebUI instance ─────────────────────────────────────────────────────────
OPENWEBUI_URL=            # e.g. http://localhost:3000  (dev) / https://owui.example.com (prod)
OPENWEBUI_API_KEY=        # Admin API key from Settings > Account in OpenWebUI

# ── LLM backend (injected into config/connections/openai.json at apply-time) ───
OPENAI_API_BASE_URL=      # e.g. http://localhost:11434/v1  (dev) / https://api.openai.com/v1 (prod)
OPENAI_API_KEY=           # e.g. ollama  (dev) / sk-...  (prod)
